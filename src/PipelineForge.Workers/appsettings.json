{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Azure": "Warning"
    }
  },
  "AzureServiceBus": {
    "ConnectionString": "",
    "PipelineEventsTopic": "pipeline-events",
    "RemediationCommandsTopic": "remediation-commands",
    "SubscriptionName": "pipelineforge-worker",
    "MaxConcurrentCalls": 10,
    "MaxAutoLockRenewalMinutes": 5
  },
  "AzureDevOps": {
    "OrganisationUrl": "https://dev.azure.com/your-org",
    "PersonalAccessToken": "",
    "ApiVersion": "7.1"
  },
  "KeyVault": {
    "Uri": "https://your-keyvault.vault.azure.net/",
    "SecretExpiryWarningDays": 7
  },
  "OpenTelemetry": {
    "ConnectionString": ""
  },
  "StuckRunDetector": {
    "DefaultTimeoutMinutes": 60,
    "PipelineTimeouts": {}
  },
  "PipelineHealthAnalyser": {
    "FailureThreshold": 3,
    "FailureWindowMinutes": 30,
    "StuckRunCheckIntervalSeconds": 60
  },
  "SecretExpiryGate": {
    "WarningDays": 7,
    "BlockingDays": 3,
    "PipelineSecrets": {}
  },
  "SecretExpiryGateWorker": {
    "CheckIntervalMinutes": 60
  }
}
